{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "arrowParens": "avoid",
  "semi": false,
  "trailingComma": "none",
  "singleQuote": true,
  "sortTailwindcss": {
    "stylesheet": "./src/styles/globals.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": false
  },
  "ignorePatterns": ["node_modules", "dist", "pnpm-lock.yaml"]
}
